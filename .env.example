# AI providers
# Cerebras is the primary extractor. Groq is the fallback when confidence is low
# or critical invoice fields are missing.
CEREBRAS_API_KEY=your-cerebras-api-key
GROQ_API_KEY=your-groq-api-key

# Database
DATABASE_URL=postgresql://docai:docai@localhost:5433/docai

# Auth
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
FRONTEND_URL=https://aidocli.netlify.app

# File upload
UPLOAD_DIR=data/raw
MAX_FILE_SIZE_MB=50

# Persistent object storage
# If these are missing or invalid, uploads fall back to local disk. On Render free
# tier, local disk is ephemeral and files can disappear after redeploys.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=doc-intel-uploads
AWS_S3_REGION_NAME=ap-south-1
# AWS_S3_ENDPOINT_URL=optional-s3-compatible-endpoint

# Email export, email verification, and password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@example.com
SMTP_PASSWORD=your-app-password

# API
LOG_LEVEL=INFO
RATE_LIMIT_WHITELISTED_IPS=
