# ── AI EXTRACTION ──────────────────────────────────────────────────────────────
# Gemini Flash free tier — replaces Claude Sonnet
# Get free key in 2 minutes: aistudio.google.com → Get API Key
# Free limits: 15 requests/minute, 1 million tokens/day
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: switch model (flash = free/fast, pro = smarter but uses more quota)
# EXTRACTION_MODEL=gemini-1.5-flash

# ── DATABASE ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://docai:docai@localhost:5433/docai

# ── FILE UPLOAD ────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/raw
MAX_FILE_SIZE_MB=50

# ── API ────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5679

# ── N8N INTEGRATIONS (optional) ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
